{
  "name": "blog",
  "version": "0.0.1",
  "private": true,
  "description": "Ifiok Jr. blog",
  "scripts": {
    "build": "sapper build",
    "check:pnpm": "node support/scripts/check-pnpm.js",
    "checks": "run-s lint typecheck test",
    "clean:all": "git clean -fdX --exclude='.config.json'",
    "dev": "sapper dev",
    "export": "sapper export",
    "fix": "run-s -c fix:*",
    "fix:md": "pnpm lint:md -- --fix",
    "fix:prettier": "pnpm run:prettier -- --write",
    "fix:svelte": "pnpm lint:svelte -- --fix",
    "fix:ts": "pnpm lint:ts -- --fix",
    "preinstall": "pnpm symlink:root && pnpm check:pnpm",
    "lint": "run-s lint:*",
    "lint:md": "eslint -f codeframe  --ignore-pattern='*.svelte' --ignore-pattern='*.js' --ignore-pattern='*.ts' .",
    "lint:prettier": "pnpm run:prettier -- --check",
    "lint:svelte": "cross-env eslint -f codeframe --ext=.svelte .",
    "lint:ts": "cross-env FULL_ESLINT_CHECK=true eslint --ignore-pattern='*.svelte' -f codeframe --ext=.ts,.js .",
    "run:prettier": "prettier --ignore-path .eslintignore \"**/*.{js,jsx,ts,tsx,md,mdx,json,html,css,yml,yaml,graphql}\"",
    "start": "node __sapper__/build",
    "symlink:root": "node support/scripts/symlink-root.js",
    "update:deps": "pnpm update --latest --recursive -i",
    "validate": "svelte-check --ignore src/node_modules/@sapper"
  },
  "dependencies": {
    "@types/marked": "^1.1.0",
    "@types/prismjs": "^1.16.1",
    "compression": "^1.7.4",
    "date-fns": "^2.16.1",
    "express": "^4.17.1",
    "gray-matter": "^4.0.2",
    "marked": "^1.2.0",
    "polka": "^0.5.2",
    "prismjs": "^1.21.0",
    "reading-time": "^1.2.0",
    "sirv": "^1.0.6",
    "svelte-image": "^0.2.7"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^15.1.0",
    "@rollup/plugin-node-resolve": "^9.0.0",
    "@rollup/plugin-replace": "^2.3.3",
    "@rollup/plugin-typescript": "^6.0.0",
    "@testing-library/dom": "^7.24.5",
    "@testing-library/svelte": "^3.0.0",
    "@tsconfig/svelte": "^1.0.10",
    "@types/autoprefixer": "^9.7.2",
    "@types/compression": "^1.7.0",
    "@types/eslint": "^7.2.4",
    "@types/jest": "^26.0.13",
    "@types/jest-axe": "^3.5.0",
    "@types/node": "^14.11.7",
    "@types/polka": "^0.5.1",
    "@types/testing-library__jest-dom": "^5.9.2",
    "@typescript-eslint/eslint-plugin": "^4.1.0",
    "@typescript-eslint/parser": "^4.1.0",
    "autoprefixer": "^9.8.6",
    "cssnano": "4.1.10",
    "eslint": "^7.8.1",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-graphql": "^4.0.0",
    "eslint-plugin-html": "^6.1.0",
    "eslint-plugin-import": "^2.22.0",
    "eslint-plugin-jest": "^24.0.0",
    "eslint-plugin-jest-formatting": "^2.0.0",
    "eslint-plugin-jsx-a11y": "^6.3.1",
    "eslint-plugin-markdown": "^2.0.0-rc.0",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-simple-import-sort": "^5.0.3",
    "eslint-plugin-sonarjs": "^0.5.0",
    "eslint-plugin-unicorn": "^22.0.0",
    "front-matter": "^4.0.2",
    "husky": "^4.3.0",
    "jest": "^26.4.2",
    "jest-circus": "^26.4.2",
    "jest-extended": "^0.11.5",
    "jest-watch-typeahead": "^0.6.1",
    "lint-staged": "^10.3.0",
    "mdsvex": "^0.8.8",
    "npm-run-all": "^4.1.5",
    "postcss": "^7.0.34",
    "postcss-nested": "^4.2.3",
    "prettier": "^2.1.1",
    "prettier-plugin-packagejson": "^2.2.5",
    "prettier-plugin-svelte": "^1.4.0",
    "remark-autolink-headings": "^6.0.1",
    "remark-footnotes": "^3.0.0",
    "remark-slug": "^6.0.0",
    "rollup": "^2.29.0",
    "rollup-plugin-copy": "^3.3.0",
    "rollup-plugin-glob": "^1.0.2",
    "rollup-plugin-svelte": "^6.0.1",
    "rollup-plugin-terser": "^7.0.2",
    "sapper": "^0.28.10",
    "snapshot-diff": "^0.8.1",
    "svelte": "^3.29.0",
    "svelte-check": "^1.0.46",
    "svelte-preprocess": "^4.5.1",
    "ts-jest": "^26.4.0",
    "tslib": "^2.0.2",
    "typescript": "4.1.0-beta",
    "typescript-snapshots-plugin": "^1.7.0"
  }
}
